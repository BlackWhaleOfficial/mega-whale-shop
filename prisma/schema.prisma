generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String        @id @default(uuid())
  uid          String        @unique
  openid       String        @unique
  username     String        @unique
  email        String        @unique
  password     String
  isAdmin      Boolean       @default(false)
  whaleCash    Int           @default(0)
  transactions Transaction[]
  discounts    UserDiscount[]
  orders       Order[]
  rollCounts   BannerRollCount[]
  createdAt    DateTime      @default(now())
}

model BannerRollCount {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  bannerName String
  count      Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@unique([userId, bannerName])
}

model Order {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  productName String
  quantity    Int      @default(1)
  totalAmount Int
  status      String   @default("PENDING") // PENDING, DONE, CANCELLED
  items       Inventory[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Inventory {
  id        String    @id @default(uuid())
  game      String
  serial    String
  pin       String
  inTime    DateTime  @default(now())
  outTime   DateTime?
  cardValue Int       @default(0)
  qh        Int       @default(0)
  cost      Int       @default(0)
  price     Int       @default(0)
  status    String    @default("NEW") // NEW, PENDING, DONE
  
  orderId   String?
  order     Order?    @relation(fields: [orderId], references: [id])
}

model UserDiscount {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  codeName        String   // vd: "Welcome (1% Off)"
  discountPercent Int
  isUsed          Boolean  @default(false)
  createdAt       DateTime @default(now())
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Int
  image       String   @default("")
  isDeck      Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model DiscountTemplate {
  id              String   @id @default(uuid())
  code            String   @unique
  discountPercent Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
}

model Subscription {
  id       String @id @default(uuid())
  name     String
  price    Int
  benefits String
}

model Transaction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Int
  type      String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model GameAccount {
  id           String   @id @default(uuid())
  gameId       String   // ID hiển thị trong game
  email        String
  password     String
  rank         String   // Đồng, Bạc, Vàng, Bạch Kim, Kim Cương, Tinh Anh, Cao Thủ
  heroesCount  Int      @default(0)
  skinsCount   Int      @default(0)
  loginType    String   // Garena, Facebook, Trắng thông tin
  notes        String   @default("")
  price        Int
  originalPrice Int?
  bannerTag    String?
  status       String   @default("AVAILABLE") // AVAILABLE, SOLD
  image        String   @default("") // Link tới ảnh gallery của acc
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
